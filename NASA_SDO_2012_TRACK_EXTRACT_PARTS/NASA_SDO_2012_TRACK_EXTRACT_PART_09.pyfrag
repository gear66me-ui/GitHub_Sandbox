    print_report(
        config,
        metadata,
        metrics,
        csv_path,
        xlsx_path,
        overlay_path,
        overlay_frame,
    )
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except KeyboardInterrupt:
        print("Execution interrupted by user.", file=sys.stderr)
        raise SystemExit(130)
